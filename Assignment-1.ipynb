# Part 6: Mini Challenges

# 17. Take temperature in Celsius and convert to Fahrenheit.
temp_cel = input("Enter temperature in Celsius: ")
celsius = float(temp_cel)
temp_f = (celsius * 9/5) + 32
print(f"{celsius}°C is equal to {temp_f}°F")

# 18. Ask user for a number and check if it is even or odd using %.
user_num_check = input("Enter a number to check if it's EVEN or ODD: ")
number_check = int(user_num_check)
if number_check % 2 == 0:
    print("The number is EVEN.")
else:
    print("The number is ODD.")

# 19. Take user input as string and convert it into Integer and Float.
input_string = input("Enter a number: ")
input_int = int(float(input_string))
input_float = float(input_string)
print("Converted to integer", input_int)
print("Converted to float", input_float)

"""
20. Create a simple calculator:
    - Take two numbers
    - Take operator (+, -, *, /)
    - Perform operation based on user choice
"""
number_1 = input("Enter the first number: ")
number_2 = input("Enter the second number: ")
op = input("Enter an operator (+, -, *, /): ")

num1 = float(number_1)
num2 = float(number_2)
if op == "+":
    print(num1 + num2)
elif op == "-":
    print(num1 - num2)
elif op == "*":
    print(num1 * num2)
elif op == "/":
    if num2 == 0:
        print("Division by zero not possible")
    else:
        print(num1 / num2)
else:
    print("Enter a valid operator")
