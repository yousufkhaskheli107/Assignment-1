# Part 2: Basic Operators

# 5. Take two numbers and perform: Addition, Subtraction, Multiplication, Division
x = 12
y = 10
print(f"Addition: {x+y}")
print(f"Subtraction: {x-y}")
print(f"Multiplication: {x*y}")
print(f"Division: {x/y}")

# 6. Store two numbers and find: Remainder using %, Power using **
a = 2
b = 8
print(f"{a} % {b} is: {a%b}")
print(f"{a}**{b} is: {a**b}")

# 7. Create a variable x = 10 and y = 3, then print x+y, x-y, x*y, x/y
x, y = 10, 3
print(f"{x}+{y}:{x+y}")
print(f"{x}-{y}:{x-y}")
print(f"{x}*{y}:{x*y}")
print(f"{x}/{y}:{x/y}")


